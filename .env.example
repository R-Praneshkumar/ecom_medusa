# ============================================
# Medusa E-Commerce - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------- DOMAIN ----------
# Your domain name (without https://)
DOMAIN=yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ---------- DATABASE ----------
POSTGRES_USER=medusa
POSTGRES_PASSWORD=change_me_strong_password_123
POSTGRES_DB=medusa_db
DATABASE_URL=postgres://medusa:change_me_strong_password_123@postgres:5432/medusa_db

# ---------- REDIS ----------
REDIS_URL=redis://redis:6379

# ---------- MEDUSA SECRETS ----------
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_supersecret_jwt_key_here
COOKIE_SECRET=change_me_supersecret_cookie_key_here

# ---------- CORS ----------
# Update these with your actual domain
STORE_CORS=https://yourdomain.com
ADMIN_CORS=https://yourdomain.com
AUTH_CORS=https://yourdomain.com

# ---------- MEDUSA ----------
MEDUSA_BACKEND_URL=https://yourdomain.com
MEDUSA_ADMIN_ONBOARDING_TYPE=default
MEDUSA_WORKER_MODE=shared
PORT=9000

# ---------- STOREFRONT ----------
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://yourdomain.com
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key_here
NEXT_PUBLIC_DEFAULT_REGION=us
REVALIDATE_SECRET=change_me_revalidate_secret

# ---------- SSL (Let's Encrypt) ----------
ACME_EMAIL=admin@yourdomain.com
